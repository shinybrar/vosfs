{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/v17.6.1/schemas/config.json",
  "label": "autorelease: pending",
  "release-label": "autorelease: tagged",
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "vosfs",
      "versioning": "default",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": true,
      "force-tag-creation": true,
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "pull-request-title-pattern": "chore: release ${version}",
      "exclude-paths": [
        "src/fsspec-cli/**",
        ".github/workflows/fsspec-cli-*.yml",
        "fsspec-cli-release-please-config.json",
        ".fsspec-cli-release-please-manifest.json",
        "docs/adr/0001-release-fsspec-cli-independently.md",
        "docs/adr/0002-own-async-filesystems-per-invocation.md",
        "docs/adr/0003-acquire-referenced-async-filesystem-sources.md",
        "docs/design/fsspec-cli-*.md",
        "docs/research/fsspec-cli-*.md"
      ],
      "extra-files": [
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name.value==\"vosfs\")].version"
        }
      ]
    }
  }
}
