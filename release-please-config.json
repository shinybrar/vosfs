{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/v17.6.1/schemas/config.json",
  "label": "autorelease: pending",
  "release-label": "autorelease: tagged",
  "separate-pull-requests": true,
  "packages": {
    ".": {
      "release-type": "python",
      "package-name": "vosfs",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": true,
      "force-tag-creation": true,
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "pull-request-title-pattern": "chore: release vosfs ${version}",
      "exclude-paths": [
        "src/fsspec-cli",
        "docs",
        ".superpowers"
      ],
      "extra-files": [
        {
          "type": "toml",
          "path": "uv.lock",
          "jsonpath": "$.package[?(@.name.value==\"vosfs\")].version"
        }
      ]
    },
    "src/fsspec-cli": {
      "package-name": "fsspec-cli",
      "release-type": "python",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "draft": true,
      "force-tag-creation": true,
      "include-component-in-tag": true,
      "component": "fsspec-cli",
      "include-v-in-tag": true,
      "initial-version": "0.1.0",
      "extra-files": [
        {
          "jsonpath": "$.package[?(@.name.value==\"fsspec-cli\")].version",
          "path": "/uv.lock",
          "type": "toml"
        }
      ]
    }
  }
}
